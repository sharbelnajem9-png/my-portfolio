  function createVideoElement(videoId, type) {
      const wrapper = document.createElement('div');
      wrapper.className = `vid-wrapper ${type}`;
      const iframe = document.createElement('iframe');
      iframe.src = `https://www.youtube.com/embed/${videoId}?rel=0&modestbranding=1`;
      iframe.allow = "accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture";
      iframe.allowFullscreen = true;
      wrapper.appendChild(iframe);
      return wrapper;
  }

  function createCoverVideo(videoId) {
      const iframe = document.createElement('iframe');
      iframe.src = `https://www.youtube.com/embed/${videoId}?autoplay=1&mute=1&loop=1&playlist=${videoId}&controls=0&rel=0&modestbranding=1`;
      iframe.allow = "autoplay; encrypted-media";
      return iframe;
  }

  // טעינת מועדפים
  const favGrid = document.getElementById('favorites-grid');
  favorites.forEach(video => {
      favGrid.appendChild(createVideoElement(video.id, video.type));
  });

  // טעינת פרויקטים
  const projGrid = document.getElementById('projects-grid');
  projectsData.forEach((project, index) => {
      const card = document.createElement('div');
      card.className = 'project-card-yt';
      card.onclick = () => openModal(index);

      const coverVid = createCoverVideo(project.coverVideoId);
      
      const overlay = document.createElement('div');
      overlay.className = 'project-title-overlay';
      const title = document.createElement('h3');
      title.innerText = project.title;
      
      overlay.appendChild(title);
      card.appendChild(coverVid);
      card.appendChild(overlay);
      
      projGrid.appendChild(card);
  });

  // מודל
  const modal = document.getElementById('project-modal');
  const modalTitle = document.getElementById('modal-title');
  const modalVideosArea = document.getElementById('modal-videos');

  function openModal(projectIndex) {
      const project = projectsData[projectIndex];
      modalTitle.innerText = project.title;
      modalVideosArea.innerHTML = '';
      
      project.videos.forEach(vid => {
          modalVideosArea.appendChild(createVideoElement(vid.id, vid.type));
      });

      modal.classList.add('active');
      document.body.style.overflow = 'hidden'; 
  }

  function closeModal() {
      modal.classList.remove('active');
      document.body.style.overflow = ''; 
      setTimeout(() => {
          modalVideosArea.innerHTML = ''; 
      }, 300); 
  }

  modal.addEventListener('click', (e) => {
      if (e.target === modal) closeModal();
  });
</script>
</body>
</html>
