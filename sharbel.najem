<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Sharbel Najem — Filmmaker & Content Creator</title>
<style>
@font-face{font-family:'Almoni';src:url(data:font/truetype;base64,) format('truetype');font-weight:400;font-style:normal;font-display:swap}
@font-face{font-family:'Assistant';src:url(data:font/truetype;base64,) format('truetype');font-weight:100 900;font-style:normal;font-display:swap}
@font-face{font-family:'AssistantSemi';src:url(data:font/truetype;base64,) format('truetype');font-weight:600;font-style:normal;font-display:swap}

:root{
--black:#0b0b0b;--dark:#0f0f0f;--card:#151515;--card-border:rgba(255,255,255,0.05);
--glass:rgba(255,255,255,0.03);--glass-border:rgba(255,255,255,0.06);--glass-hover:rgba(255,255,255,0.06);
--white:#f2f2f0;--white-90:rgba(242,242,240,0.9);--white-70:rgba(242,242,240,0.7);
--white-50:rgba(242,242,240,0.5);--white-30:rgba(242,242,240,0.3);--white-15:rgba(242,242,240,0.15);
--white-08:rgba(242,242,240,0.08);
--radius:14px;--radius-sm:10px;--radius-lg:20px;
--font-en:'Almoni',sans-serif;--font-he-title:'AssistantSemi','Assistant',sans-serif;--font-he-body:'Assistant',sans-serif;
--font-display:var(--font-en);--font-body:var(--font-en);
}
[dir="rtl"]{--font-display:var(--font-he-title);--font-body:var(--font-he-body)}
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth;scrollbar-width:thin;scrollbar-color:var(--white-15) transparent}
body{font-family:var(--font-body);background:var(--black);color:var(--white);overflow-x:hidden;-webkit-font-smoothing:antialiased}
::-webkit-scrollbar{width:5px}::-webkit-scrollbar-track{background:transparent}::-webkit-scrollbar-thumb{background:var(--white-15);border-radius:3px}

.navbar{position:fixed;top:0;left:0;right:0;z-index:1000;padding:16px 48px;display:flex;align-items:center;justify-content:space-between;backdrop-filter:blur(24px) saturate(1.3);-webkit-backdrop-filter:blur(24px) saturate(1.3);background:rgba(11,11,11,0.6);border-bottom:1px solid var(--glass-border);transition:all 0.4s}
.navbar.scrolled{padding:10px 48px;background:rgba(11,11,11,0.88)}
.nav-logo img{height:44px;transition:opacity 0.3s}
.nav-logo:hover img{opacity:0.7}
.nav-links{display:flex;gap:40px;list-style:none}
.nav-links a{color:var(--white-50);text-decoration:none;font-size:14px;font-weight:400;letter-spacing:0.8px;text-transform:uppercase;transition:color 0.3s;position:relative}
.nav-links a::after{content:'';position:absolute;bottom:-4px;left:0;width:0;height:1px;background:var(--white);transition:width 0.3s}
.nav-links a:hover{color:var(--white)}.nav-links a:hover::after{width:100%}
.nav-right{display:flex;align-items:center;gap:14px}
.nav-socials{display:flex;gap:14px}
.nav-socials a{color:var(--white-30);transition:color 0.3s,transform 0.3s;display:flex}
.nav-socials a:hover{color:var(--white);transform:translateY(-2px)}
.lang-toggle{background:var(--glass);border:1px solid var(--glass-border);color:var(--white-70);padding:6px 16px;border-radius:20px;cursor:pointer;font-size:13px;font-family:var(--font-body);transition:all 0.3s}
.lang-toggle:hover{background:var(--glass-hover);border-color:var(--white-15)}
.a11y-btn{background:var(--glass);border:1px solid var(--glass-border);color:var(--white-50);width:34px;height:34px;border-radius:50%;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all 0.3s}
.a11y-btn:hover{background:var(--glass-hover);border-color:var(--white-15)}
.a11y-btn svg{width:18px;height:18px}
.mobile-menu-btn{display:none;flex-direction:column;gap:5px;cursor:pointer;background:none;border:none;padding:4px}
.mobile-menu-btn span{display:block;width:22px;height:1.5px;background:var(--white);transition:all 0.3s}

/* A11Y PANEL */
.a11y-panel{position:fixed;top:0;right:-360px;width:340px;height:100vh;z-index:2000;background:rgba(18,18,18,0.97);backdrop-filter:blur(30px);border-left:1px solid var(--glass-border);padding:32px 24px;transition:right 0.35s;overflow-y:auto}
.a11y-panel.open{right:0}
.a11y-panel-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:28px}
.a11y-panel-header h3{font-family:var(--font-display);font-size:18px;font-weight:600}
.a11y-close{background:none;border:none;color:var(--white);font-size:24px;cursor:pointer}
.a11y-option{display:flex;justify-content:space-between;align-items:center;padding:14px 0;border-bottom:1px solid var(--white-08)}
.a11y-option span{font-size:14px;color:var(--white-70)}
.a11y-toggle{width:44px;height:24px;border-radius:12px;background:var(--white-15);border:none;cursor:pointer;position:relative;transition:background 0.3s}
.a11y-toggle.active{background:var(--white-50)}
.a11y-toggle::after{content:'';position:absolute;top:3px;left:3px;width:18px;height:18px;border-radius:50%;background:var(--white);transition:transform 0.3s}
.a11y-toggle.active::after{transform:translateX(20px)}
.a11y-overlay{position:fixed;inset:0;z-index:1999;background:rgba(0,0,0,0.5);opacity:0;pointer-events:none;transition:opacity 0.3s}
.a11y-overlay.open{opacity:1;pointer-events:all}

/* HERO */
.hero{position:relative;height:100vh;min-height:650px;display:flex;align-items:center;justify-content:center;overflow:hidden}
.hero-video-bg{position:absolute;inset:0;background:var(--dark);overflow:hidden}
.hero-video-bg video{width:100%;height:100%;object-fit:cover;opacity:0.4}
.hero-video-placeholder{width:100%;height:100%;background:linear-gradient(160deg,#0b0b0b 0%,#14141e 50%,#0b0b0b 100%);display:flex;align-items:center;justify-content:center}
.hero-video-placeholder::after{content:'▶ Replace with your showreel';color:var(--white-15);font-size:13px;letter-spacing:2px;text-transform:uppercase}
.hero-overlay{position:absolute;inset:0;background:linear-gradient(to bottom,rgba(11,11,11,0.2) 0%,rgba(11,11,11,0.05) 40%,rgba(11,11,11,0.75) 100%)}
.hero-content{position:relative;z-index:2;text-align:center;display:flex;flex-direction:column;align-items:center;gap:18px;animation:heroIn 1s ease-out}
@keyframes heroIn{from{opacity:0;transform:translateY(24px)}to{opacity:1;transform:translateY(0)}}
.hero-avatar{width:88px;height:88px;border-radius:50%;border:2px solid var(--white-15);overflow:hidden;background:var(--card);box-shadow:0 0 30px rgba(0,0,0,0.4)}
.hero-avatar img{width:100%;height:100%;object-fit:cover}
.hero-name{font-family:var(--font-display);font-size:clamp(40px,7vw,76px);font-weight:600;letter-spacing:-1px;line-height:1}
.hero-tagline{font-size:15px;color:var(--white-50);max-width:480px;font-weight:300;line-height:1.6}
.hero-scroll{position:absolute;bottom:36px;left:50%;transform:translateX(-50%);display:flex;flex-direction:column;align-items:center;gap:8px;color:var(--white-15);font-size:10px;letter-spacing:3px;text-transform:uppercase;animation:scrollB 2s infinite}
@keyframes scrollB{0%,100%{transform:translateX(-50%) translateY(0)}50%{transform:translateX(-50%) translateY(6px)}}
.scroll-line{width:1px;height:36px;background:linear-gradient(to bottom,var(--white-15),transparent)}

section{padding:120px 60px}
.section-label{font-size:11px;letter-spacing:4px;text-transform:uppercase;color:var(--white-50);margin-bottom:10px;font-weight:400}
.section-title{font-family:var(--font-display);font-size:clamp(30px,4.5vw,50px);font-weight:600;letter-spacing:-0.5px;margin-bottom:16px}
.section-subtitle{color:var(--white-50);font-size:15px;max-width:560px;line-height:1.7;font-weight:300}

/* ABOUT */
.about{background:var(--dark)}
.about-grid{display:grid;grid-template-columns:0.75fr 1.25fr;gap:72px;max-width:1100px;margin:0 auto;align-items:center}
.about-image-wrapper{position:relative;border-radius:var(--radius-lg);overflow:hidden;aspect-ratio:3/4;background:var(--card)}
.about-image-wrapper img{width:100%;height:100%;object-fit:cover}
.about-text p{color:var(--white-50);line-height:1.85;margin-bottom:18px;font-weight:300;font-size:15px}
.about-links{display:flex;flex-wrap:wrap;gap:10px;margin-top:28px}
.about-link{display:flex;align-items:center;gap:10px;padding:10px 18px;background:var(--glass);border:1px solid var(--glass-border);border-radius:var(--radius);color:var(--white-70);text-decoration:none;font-size:13px;transition:all 0.3s;backdrop-filter:blur(10px)}
.about-link:hover{background:var(--glass-hover);border-color:var(--white-15);transform:translateY(-2px)}
.about-link .follower-count{color:var(--white-30);font-size:11px;margin-left:2px}

/* SERVICES */
.services{background:var(--black)}
.services-header{text-align:center;margin-bottom:56px}
.services-header .section-subtitle{margin:0 auto}
.services-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:16px;max-width:1200px;margin:0 auto}
.service-card{background:var(--glass);border:1px solid var(--glass-border);border-radius:var(--radius);padding:32px 24px;backdrop-filter:blur(20px);transition:all 0.4s;position:relative;overflow:hidden}
.service-card:hover{background:var(--glass-hover);border-color:var(--white-15);transform:translateY(-3px);box-shadow:0 16px 48px rgba(0,0,0,0.3)}
.service-icon{width:40px;height:40px;border-radius:10px;background:var(--white-08);display:flex;align-items:center;justify-content:center;margin-bottom:18px;color:var(--white-50)}
.service-card h3{font-family:var(--font-display);font-size:16px;font-weight:600;margin-bottom:8px}
.service-card p{color:var(--white-30);font-size:13px;line-height:1.6;font-weight:300}

/* BRANDS */
.brands{background:var(--dark);overflow:hidden}
.brands-header{text-align:center;margin-bottom:48px}
.brand-marquee{position:relative;overflow:hidden;padding:16px 0;mask-image:linear-gradient(90deg,transparent,black 10%,black 90%,transparent);-webkit-mask-image:linear-gradient(90deg,transparent,black 10%,black 90%,transparent)}
.brand-track{display:flex;gap:56px;animation:marquee 50s linear infinite;width:max-content}
.brand-track:hover{animation-play-state:paused}
@keyframes marquee{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}
.brand-item{display:flex;align-items:center;justify-content:center;min-width:130px;height:50px;color:var(--white-30);font-family:var(--font-display);font-size:18px;font-weight:600;letter-spacing:1px;opacity:0.35;transition:opacity 0.3s;white-space:nowrap;flex-shrink:0}
.brand-item:hover{opacity:0.7}
.testimonials-marquee{position:relative;overflow:hidden;margin-top:40px;padding:16px 0;mask-image:linear-gradient(90deg,transparent,black 6%,black 94%,transparent);-webkit-mask-image:linear-gradient(90deg,transparent,black 6%,black 94%,transparent)}
.testimonial-track{display:flex;gap:20px;animation:testScroll 55s linear infinite;width:max-content}
.testimonial-track:hover{animation-play-state:paused}
@keyframes testScroll{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}
.testimonial-card{background:var(--glass);border:1px solid var(--glass-border);border-radius:var(--radius);padding:28px;backdrop-filter:blur(20px);min-width:340px;max-width:380px;flex-shrink:0;transition:all 0.3s}
.testimonial-card:hover{background:var(--glass-hover);border-color:var(--white-15)}
.testimonial-stars{color:#d4a853;font-size:13px;margin-bottom:14px;letter-spacing:2px}
.testimonial-text{color:var(--white-50);font-size:14px;line-height:1.7;font-style:italic;margin-bottom:16px;font-weight:300}
.testimonial-brand{font-family:var(--font-display);font-weight:600;font-size:14px;color:var(--white-70)}

/* PROJECTS */
.projects{background:var(--black)}
.projects-header{text-align:center;margin-bottom:40px}
.folders-wrapper{position:relative;max-width:100%;margin:0 auto 60px;overflow:hidden}
.folders-carousel{overflow:hidden;mask-image:linear-gradient(90deg,transparent,black 3%,black 97%,transparent);-webkit-mask-image:linear-gradient(90deg,transparent,black 3%,black 97%,transparent)}
.folders-track{display:flex;gap:20px;animation:foldersScroll 65s linear infinite;width:max-content;padding:8px 0}
.folders-track:hover{animation-play-state:paused}
@keyframes foldersScroll{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}
.folder-card{min-width:320px;max-width:340px;border-radius:var(--radius);overflow:hidden;background:var(--card);border:1px solid var(--card-border);flex-shrink:0;cursor:pointer;transition:transform 0.4s,box-shadow 0.4s}
.folder-card:hover{transform:translateY(-4px);box-shadow:0 16px 48px rgba(0,0,0,0.4)}
.folder-thumb{width:100%;aspect-ratio:16/10;background:linear-gradient(135deg,#141418,#1c1c28);display:flex;align-items:center;justify-content:center;color:var(--white-15);font-size:11px;letter-spacing:2px;text-transform:uppercase;position:relative}
.folder-thumb::after{content:'▶';position:absolute;font-size:28px;color:var(--white-15)}
.folder-info{padding:18px 20px}
.folder-info h4{font-family:var(--font-display);font-size:16px;font-weight:600;margin-bottom:6px}
.folder-info p{color:var(--white-30);font-size:13px;line-height:1.5;font-weight:300}
.folder-info .folder-cat{font-size:11px;color:var(--white-30);text-transform:uppercase;letter-spacing:1.5px;margin-bottom:4px}
.folder-nav{display:flex;justify-content:center;gap:12px;margin-top:20px}
.folder-nav button{width:40px;height:40px;border-radius:50%;background:var(--glass);border:1px solid var(--glass-border);color:var(--white-50);cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all 0.3s;font-size:16px}
.folder-nav button:hover{background:var(--glass-hover);border-color:var(--white-15);color:var(--white)}
.featured-strip{position:relative;overflow:hidden;mask-image:linear-gradient(90deg,transparent,black 4%,black 96%,transparent);-webkit-mask-image:linear-gradient(90deg,transparent,black 4%,black 96%,transparent)}
.featured-track{display:flex;gap:16px;animation:featuredScroll 50s linear infinite;width:max-content}
@keyframes featuredScroll{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}
.featured-item{width:360px;aspect-ratio:16/9;border-radius:var(--radius-sm);overflow:hidden;background:var(--card);flex-shrink:0;display:flex;align-items:center;justify-content:center;color:var(--white-08);font-size:11px;letter-spacing:2px;text-transform:uppercase;position:relative}
.featured-item::after{content:'▶';position:absolute;font-size:24px;color:var(--white-15)}
.featured-label{text-align:center;margin-bottom:24px}

.contact{background:var(--black);text-align:center;padding:140px 60px}
.contact-big-text{font-family:var(--font-display);font-size:clamp(26px,4.5vw,46px);font-weight:600;max-width:720px;margin:0 auto 44px;line-height:1.25;letter-spacing:-0.5px}
.contact-big-text em{font-style:italic;color:var(--white-90)}
.contact-btn{display:inline-flex;align-items:center;gap:12px;padding:16px 36px;background:var(--white);color:var(--black);border:none;border-radius:50px;font-size:15px;font-weight:600;font-family:var(--font-display);cursor:pointer;text-decoration:none;transition:all 0.3s}
.contact-btn:hover{transform:scale(1.04);box-shadow:0 0 36px rgba(242,242,240,0.1)}

.footer{border-top:1px solid var(--glass-border);padding:28px 60px;display:flex;justify-content:space-between;align-items:center;background:var(--black)}
.footer-text{color:var(--white-30);font-size:12px}
.footer-socials{display:flex;gap:16px}
.footer-socials a{color:var(--white-30);transition:color 0.3s;display:flex}
.footer-socials a:hover{color:var(--white)}
<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>הפרויקטים והסרטונים שלי</title>
    <style>
        /* === עיצוב בסיסי וקטלני (Dark Mode Style) === */
        :root {
            --bg-color: #121212;
            --text-color: #ffffff;
            --card-bg: #1e1e1e;
            --accent-color: #e50914; /* צבע אדום שמזכיר וידאו/יוטיוב */
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: var(--bg-color);
            color: var(--text-color);
            margin: 0;
            padding: 20px;
            line-height: 1.6;
        }

        h2 {
            text-align: center;
            font-size: 2.5em;
            margin-bottom: 30px;
            text-shadow: 0 2px 4px rgba(0,0,0,0.5);
        }

        .section-divider {
            border: 0;
            height: 1px;
            background: linear-gradient(to right, transparent, #333, transparent);
            margin: 50px 0;
        }

        /* === גריד מועדפים === */
        .video-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
            gap: 20px;
            justify-items: center;
        }

        /* טיפול ביחסי תמונה (אורך/רוחב) */
        .vid-wrapper {
            width: 100%;
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 4px 15px rgba(0,0,0,0.3);
            background: #000;
        }
        .vid-wrapper.short { aspect-ratio: 9 / 16; }
        .vid-wrapper.regular { aspect-ratio: 16 / 9; }
        
        .vid-wrapper iframe {
            width: 100%;
            height: 100%;
            border: none;
        }

        /* === כרטיסיות פרויקטים מבחוץ === */
        .projects-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 30px;
        }

        .project-card {
            position: relative;
            aspect-ratio: 16 / 9;
            border-radius: 16px;
            overflow: hidden;
            cursor: pointer;
            box-shadow: 0 8px 20px rgba(0,0,0,0.5);
            transition: transform 0.3s ease, box-shadow 0.3s ease;
            background: #000;
        }

        .project-card:hover {
            transform: translateY(-5px) scale(1.02);
            box-shadow: 0 12px 30px rgba(229, 9, 20, 0.4);
        }

        /* סרטון הרקע בכרטיסייה החיצונית (פעיל אך לא לחיץ) */
        .project-card iframe {
            width: 100%;
            height: 100%;
            border: none;
            pointer-events: none; /* מונע לחיצה על הוידאו כדי שהקליק יפתח את הפרויקט */
            opacity: 0.6; /* טיפה כהה כדי שהטקסט יבלוט */
            transition: opacity 0.3s;
        }

        .project-card:hover iframe {
            opacity: 0.8;
        }

        /* שכבת הטקסט על הפרויקט */
        .project-title-overlay {
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(to top, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.2) 100%);
            z-index: 2;
        }

        .project-title-overlay h3 {
            margin: 0;
            padding: 10px 20px;
            font-size: 1.8em;
            text-align: center;
            text-shadow: 2px 2px 8px rgba(0,0,0,0.8);
            word-break: break-word;
        }

        /* === חלון קופץ (Modal) לפרויקט === */
        .modal-overlay {
            position: fixed;
            top: 0; left: 0; right: 0; bottom: 0;
            background: rgba(0,0,0,0.9);
            z-index: 1000;
            display: flex;
            justify-content: center;
            align-items: center;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.3s ease;
            backdrop-filter: blur(10px);
        }

        .modal-overlay.active {
            opacity: 1;
            pointer-events: auto;
        }

        .modal-content {
            background: var(--card-bg);
            width: 90%;
            max-width: 1200px;
            height: 85vh;
            border-radius: 20px;
            position: relative;
            display: flex;
            flex-direction: column;
            box-shadow: 0 0 40px rgba(0,0,0,0.8);
            transform: scale(0.95);
            transition: transform 0.3s ease;
            border: 1px solid #333;
        }

        .modal-overlay.active .modal-content {
            transform: scale(1);
        }

        .modal-header {
            padding: 20px 30px;
            border-bottom: 1px solid #333;
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: rgba(30,30,30,0.95);
            border-radius: 20px 20px 0 0;
        }

        .modal-header h2 {
            margin: 0;
            font-size: 2em;
        }

        .close-btn {
            background: none;
            border: none;
            color: #fff;
            font-size: 2.5em;
            cursor: pointer;
            line-height: 1;
            transition: color 0.2s;
        }

        .close-btn:hover { color: var(--accent-color); }

        .modal-body {
            padding: 30px;
            overflow-y: auto;
            flex-grow: 1;
        }

        /* גריד פנימי של הפרויקט */
        .project-videos-layout {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 25px;
            justify-items: center;
        }

        /* קוסמטיקה לפס גלילה בתוך החלון */
        .modal-body::-webkit-scrollbar { width: 8px; }
        .modal-body::-webkit-scrollbar-track { background: var(--bg-color); }
        .modal-body::-webkit-scrollbar-thumb { background: #555; border-radius: 10px; }
        .modal-body::-webkit-scrollbar-thumb:hover { background: var(--accent-color); }

    </style>
</head>
<body>

    <div id="favorites-section">
        <h2>סרטונים מועדפים 🔥</h2>
        <div id="favorites-grid" class="video-grid"></div>
    </div>

    <hr class="section-divider">

    <div id="projects-section">
        <h2>הפרויקטים שלי 🎬</h2>
        <div id="projects-grid" class="projects-grid"></div>
    </div>

    <div id="project-modal" class="modal-overlay">
        <div class="modal-content">
            <div class="modal-header">
                <h2 id="modal-title">שם הפרויקט</h2>
                <button class="close-btn" onclick="closeModal()">&times;</button>
            </div>
            <div class="modal-body">
                <div id="modal-videos" class="project-videos-layout"></div>
            </div>
        </div>
    </div>

    <script>
        // === נתונים ===
        
        // 1. מועדפים (כולל הגדרת סוג הסרטון לצורך עיצוב נכון)
        const favorites = [
            { id: "fLC4ozAwIy4", type: "short" }, { id: "B7jlnjqGoYM", type: "short" },
            { id: "tJ6X18bg3AM", type: "short" }, { id: "fUuuqmBUZvU", type: "short" },
            { id: "kqSvuenhlNk", type: "short" }, { id: "Q8OU-gtThTk", type: "short" },
            { id: "E7D6tVSff9c", type: "short" }, { id: "FZwLq_b1jJQ", type: "short" },
            { id: "NnWmPEr5HNc", type: "regular" }, { id: "NJj3ZdB3JVw", type: "short" },
            { id: "lflJ219lmwg", type: "short" }, { id: "JL3Tmc45rJw", type: "regular" },
            { id: "UUp-zoFAZKU", type: "regular" }, { id: "J2KJYLRMIIM", type: "short" },
            { id: "0aWLRPdA3J4", type: "short" }, { id: "iEVwhltzPiE", type: "regular" },
            { id: "XwNqsQ1-n9g", type: "regular" }, { id: "iUFH3oRuMI8", type: "regular" },
            { id: "pKbUd34fPjo", type: "regular" }, { id: "54X0PiqYA88", type: "regular" },
            { id: "c54zF_7IOwo", type: "regular" }
        ];

        // 2. פרויקטים (מאוגדים תחת כותרת אחת)
        const projectsData = [
            {
                title: "Podcast",
                playlistId: "PLxqLP3PD9uxm0NoKNJ61zPpt3sptBSaDk",
                coverVideoId: "iHCMzmN7Yiw",
                videos: [
                    { id: "iHCMzmN7Yiw", type: "short" }, { id: "flh0fYWu0U0", type: "short" },
                    { id: "RKcJQcWUdWw", type: "short" }, { id: "lCa_yrZCbyQ", type: "short" }
                ]
            },
            {
                title: "Real Estate & Interior Design",
                playlistId: "PLxqLP3PD9uxlG4RcsPhAi1Rqjij_kHYaz",
                coverVideoId: "0LWdH_13Nk4",
                videos: [
                    { id: "0LWdH_13Nk4", type: "short" }, { id: "wqBzz4bmc5U", type: "short" },
                    { id: "7Fzj0sxoJeg", type: "short" }, { id: "hVrYX7ACOnY", type: "short" },
                    { id: "0CgusHan-Lg", type: "short" }, { id: "F4Tlzd_Es5I", type: "short" },
                    { id: "GQYE4mDhFxo", type: "short" }
                ]
            },
            {
                title: "Hotels",
                playlistId: "PLxqLP3PD9uxnqSMn49Ekaz06pWcFtVcHd",
                coverVideoId: "mtc8M91PBHI", // שורט ראשון כקאבר
                videos: [
                    { id: "mtc8M91PBHI", type: "short" }, { id: "vL_uCo50aoI", type: "regular" },
                    { id: "HpmxjaMdaFM", type: "regular" }, { id: "ePshwYQIJJA", type: "regular" },
                    { id: "WN5FhwN6gVU", type: "short" }, { id: "4azt96uWZcM", type: "short" }
                ]
            },
            {
                title: "Travel",
                playlistId: "PLxqLP3PD9uxlOsh8yJYbWqK-bfZ1cZ4aq",
                coverVideoId: "otSm2afOdvE",
                videos: [
                    { id: "otSm2afOdvE", type: "regular" }, { id: "e6WifnHaPgQ", type: "regular" },
                    { id: "MPQLD-Ucv8Q", type: "regular" }, { id: "QiAQCXHSk54", type: "regular" },
                    { id: "KAZTt4Ar8AU", type: "regular" }, { id: "NnWmPEr5HNc", type: "regular" }
                ]
            },
            {
                title: "Technology",
                playlistId: "PLxqLP3PD9uxlJiD51fnGeQnEvdH9j_DEb",
                coverVideoId: "z9zX0DtTy-o",
                videos: [
                    { id: "z9zX0DtTy-o", type: "regular" }
                ]
            },
            {
                title: "Tourism & Companies",
                playlistId: "PLxqLP3PD9uxlGZWE3XUEMrbVAk-v0OTia",
                coverVideoId: "87N7DjpVA0g",
                videos: [
                    { id: "87N7DjpVA0g", type: "regular" }, { id: "mWY1fUCgA-w", type: "regular" },
                    { id: "KEHy7vxuqhU", type: "regular" }, { id: "P5c-ky1U4pQ", type: "short" },
                    { id: "A0eVEzYTQAk", type: "short" }
                ]
            }
        ];

        // === פונקציות יצירת אלמנטים ===

        // יצירת וידאו סטנדרטי (ניתן לשלוט בווליום)
        function createVideoElement(videoId, type) {
            const wrapper = document.createElement('div');
            wrapper.className = `vid-wrapper ${type}`;
            // modestbranding=1 ו-rel=0 מעלימים מיתוג של יוטיוב ככל הניתן
            // controls=1 (ברירת מחדל) מאפשר שליטה בווליום, מסך מלא ועוד
            const iframe = document.createElement('iframe');
            iframe.src = `https://www.youtube.com/embed/${videoId}?rel=0&modestbranding=1`;
            iframe.allow = "accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture";
            iframe.allowFullscreen = true;
            wrapper.appendChild(iframe);
            return wrapper;
        }

        // יצירת סרטון רקע לכרטיסיית הפרויקט (מושתק, בלופ, מתנגן אוטומטית)
        function createCoverVideo(videoId) {
            const iframe = document.createElement('iframe');
            // autoplay=1, mute=1 חובה כדי שיוטיוב יאפשר ניגון אוטומטי מבחוץ
            iframe.src = `https://www.youtube.com/embed/${videoId}?autoplay=1&mute=1&loop=1&playlist=${videoId}&controls=0&rel=0&modestbranding=1`;
            iframe.allow = "autoplay; encrypted-media";
            return iframe;
        }

        // === טעינת הנתונים למסך ===

        // טעינת מועדפים
        const favGrid = document.getElementById('favorites-grid');
        favorites.forEach(video => {
            favGrid.appendChild(createVideoElement(video.id, video.type));
        });

        // טעינת פרויקטים (תצוגה חיצונית)
        const projGrid = document.getElementById('projects-grid');
        projectsData.forEach((project, index) => {
            const card = document.createElement('div');
            card.className = 'project-card';
            card.onclick = () => openModal(index);

            // סרטון אווירה מיוט בחוץ
            const coverVid = createCoverVideo(project.coverVideoId);
            
            // שכבת טקסט
            const overlay = document.createElement('div');
            overlay.className = 'project-title-overlay';
            const title = document.createElement('h3');
            title.innerText = project.title;
            
            overlay.appendChild(title);
            card.appendChild(coverVid);
            card.appendChild(overlay);
            
            projGrid.appendChild(card);
        });

        // === פונקציות חלון קופץ (Modal) ===
        const modal = document.getElementById('project-modal');
        const modalTitle = document.getElementById('modal-title');
        const modalVideosArea = document.getElementById('modal-videos');

        function openModal(projectIndex) {
            const project = projectsData[projectIndex];
            modalTitle.innerText = project.title;
            
            // ניקוי סרטונים קודמים מהמודל
            modalVideosArea.innerHTML = '';
            
            // הזרקת הסרטונים של הפרויקט הנבחר
            project.videos.forEach(vid => {
                modalVideosArea.appendChild(createVideoElement(vid.id, vid.type));
            });

            // פתיחת המודל
            modal.classList.add('active');
            document.body.style.overflow = 'hidden'; // מונע גלילה של כל האתר בזמן שהמודל פתוח
        }

        function closeModal() {
            modal.classList.remove('active');
            document.body.style.overflow = 'auto'; // מחזיר גלילה לאתר
            
            // עוצר את ניגון הסרטונים בעת סגירה
            setTimeout(() => {
                modalVideosArea.innerHTML = ''; 
            }, 300); // מחכה לסיום האנימציה של הסגירה
        }

        // סגירת המודל בלחיצה מחוץ לחלון התוכן
        modal.addEventListener('click', (e) => {
            if (e.target === modal) {
                closeModal();
            }
        });
    </script>
</body>
</html>
/* FADE IN ANIMATIONS */
.fade-in{opacity:0;transform:translateY(24px);transition:opacity 0.7s ease,transform 0.7s ease}
.fade-in.visible{opacity:1;transform:translateY(0)}
.fade-in-left{opacity:0;transform:translateX(-30px);transition:opacity 0.7s ease,transform 0.7s ease}
.fade-in-left.visible{opacity:1;transform:translateX(0)}
.fade-in-right{opacity:0;transform:translateX(30px);transition:opacity 0.7s ease,transform 0.7s ease}
.fade-in-right.visible{opacity:1;transform:translateX(0)}
.fade-in-scale{opacity:0;transform:scale(0.95);transition:opacity 0.6s ease,transform 0.6s ease}
.fade-in-scale.visible{opacity:1;transform:scale(1)}

.mobile-nav-overlay{position:fixed;inset:0;z-index:999;background:rgba(11,11,11,0.97);backdrop-filter:blur(30px);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:28px;opacity:0;pointer-events:none;transition:opacity 0.3s}
.mobile-nav-overlay.open{opacity:1;pointer-events:all}
.mobile-nav-overlay a{color:var(--white);text-decoration:none;font-size:26px;font-family:var(--font-display);font-weight:600;transition:opacity 0.3s}
.mobile-nav-overlay a:hover{opacity:0.6}
.mobile-nav-close{position:absolute;top:24px;right:32px;background:none;border:none;color:var(--white);font-size:28px;cursor:pointer}

body.high-contrast{--white:#ffffff;--white-90:rgba(255,255,255,0.95);--white-70:rgba(255,255,255,0.85);--white-50:rgba(255,255,255,0.75);--white-30:rgba(255,255,255,0.6);--white-15:rgba(255,255,255,0.3);--glass-border:rgba(255,255,255,0.2)}
body.large-text{font-size:18px}
body.large-text .hero-tagline,body.large-text .about-text p,body.large-text .service-card p,body.large-text .testimonial-text{font-size:18px}
body.large-text .section-title{font-size:clamp(36px,5vw,60px)}
body.highlight-links a{outline:2px solid var(--white);outline-offset:2px}
body.reduce-motion *,body.reduce-motion *::before,body.reduce-motion *::after{animation:none!important;transition-duration:0.01ms!important}

@media(max-width:900px){
  section{padding:80px 24px}
  .navbar{padding:14px 20px}.nav-links{display:none}.nav-socials{display:none}.mobile-menu-btn{display:flex}
  .about-grid{grid-template-columns:1fr;gap:36px}
  .about-image-wrapper{max-height:360px;aspect-ratio:auto}
  .services-grid{grid-template-columns:1fr 1fr}
  .footer{flex-direction:column;gap:14px;text-align:center;padding:20px}
  .contact{padding:80px 24px}
  .folder-card{min-width:280px}.featured-item{width:280px}
  .a11y-panel{width:100%;right:-100%}
}
@media(max-width:600px){.hero-name{letter-spacing:0}.folder-card{min-width:260px}.featured-item{width:240px}.services-grid{grid-template-columns:1fr}}
[dir="rtl"] .about-grid{direction:rtl}[dir="rtl"] .about-text{text-align:right}
[dir="rtl"] .a11y-panel{right:auto;left:-360px;border-left:none;border-right:1px solid var(--glass-border)}[dir="rtl"] .a11y-panel.open{left:0}
</style>
</head>
<body>

<nav class="navbar" id="navbar">
  <a href="#" class="nav-logo">
    <img src="data:image/png;base64," alt="Sharbel Najem Logo">
  </a>
  <ul class="nav-links">
    <li><a href="#projects" data-en="Projects" data-he="פרויקטים">Projects</a></li>
    <li><a href="#about" data-en="About" data-he="אודות">About</a></li>
    <li><a href="#contact" data-en="Contact" data-he="צור קשר">Contact</a></li>
  </ul>
  <div class="nav-right">
    <div class="nav-socials">
      <a href="https://www.instagram.com/sharbel.najem" target="_blank" aria-label="Instagram"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg></a>
      <a href="https://youtube.com/@sharbelnajem." target="_blank" aria-label="YouTube"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22.54 6.42a2.78 2.78 0 00-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 00-1.94 2A29 29 0 001 12a29 29 0 00.46 5.58 2.78 2.78 0 001.94 2C5.12 20 12 20 12 20s6.88 0 8.6-.46a2.78 2.78 0 001.94-2A29 29 0 0023 12a29 29 0 00-.46-5.58z"/><polygon points="9.75 15.02 15.5 12 9.75 8.98"/></svg></a>
      <a href="https://www.tiktok.com/@sharbelnajem" target="_blank" aria-label="TikTok"><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.27 6.27 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.34-6.34V8.75a8.18 8.18 0 004.76 1.52V6.84a4.86 4.86 0 01-1-.15z"/></svg></a>
    </div>
    <button class="a11y-btn" onclick="openA11y()" aria-label="Accessibility settings"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="4.5" r="2.5"/><path d="M12 7v5m0 0l-3 5m3-5l3 5"/><path d="M7 11h10"/></svg></button>
    <button class="lang-toggle" id="langToggle" onclick="toggleLang()">עב</button>
    <button class="mobile-menu-btn" onclick="openMobileNav()"><span></span><span></span><span></span></button>
  </div>
</nav>

<div class="a11y-overlay" id="a11yOverlay" onclick="closeA11y()"></div>
<div class="a11y-panel" id="a11yPanel">
  <div class="a11y-panel-header"><h3 data-en="Accessibility" data-he="נגישות">Accessibility</h3><button class="a11y-close" onclick="closeA11y()">&times;</button></div>
  <div class="a11y-option"><span data-en="High Contrast" data-he="ניגודיות גבוהה">High Contrast</span><button class="a11y-toggle" onclick="toggleA11y('high-contrast',this)"></button></div>
  <div class="a11y-option"><span data-en="Large Text" data-he="טקסט גדול">Large Text</span><button class="a11y-toggle" onclick="toggleA11y('large-text',this)"></button></div>
  <div class="a11y-option"><span data-en="Highlight Links" data-he="הדגשת קישורים">Highlight Links</span><button class="a11y-toggle" onclick="toggleA11y('highlight-links',this)"></button></div>
  <div class="a11y-option"><span data-en="Reduce Motion" data-he="הפחתת תנועה">Reduce Motion</span><button class="a11y-toggle" onclick="toggleA11y('reduce-motion',this)"></button></div>
</div>

<div class="mobile-nav-overlay" id="mobileNav">
  <button class="mobile-nav-close" onclick="closeMobileNav()">&times;</button>
  <a href="#projects" onclick="closeMobileNav()" data-en="Projects" data-he="פרויקטים">Projects</a>
  <a href="#about" onclick="closeMobileNav()" data-en="About" data-he="אודות">About</a>
  <a href="#contact" onclick="closeMobileNav()" data-en="Contact" data-he="צור קשר">Contact</a>
</div>

<!-- HERO -->
<section class="hero" id="hero">
  <div class="hero-video-bg"><div class="hero-video-placeholder"></div></div>
  <div class="hero-overlay"></div>
  <div class="hero-content">
    <div class="hero-avatar"><img src="data:image/jpeg;base64," alt="Sharbel Najem"></div>
    <h1 class="hero-name">Sharbel Najem</h1>
    <p class="hero-tagline" data-en="Professional filmmaker and content creator — delivering cinematic visuals that tell stories and drive real results for brands." data-he="צלם מקצועי ויוצר תוכן — מייצר ויזואלים קולנועיים שמספרים סיפור ומניעים תוצאות אמיתיות למותגים.">Professional filmmaker and content creator — delivering cinematic visuals that tell stories and drive real results for brands.</p>
  </div>
  <div class="hero-scroll"><span data-en="Scroll" data-he="גלול">Scroll</span><div class="scroll-line"></div></div>
</section>

<!-- ABOUT -->
<section class="about" id="about">
  <div class="about-grid">
    <div class="about-image-wrapper fade-in-left">
      <img src="data:image/jpeg;base64," alt="Sharbel Najem">
    </div>
    <div class="about-text fade-in-right">
      <span class="section-label" data-en="About" data-he="אודות">About</span>
      <h2 class="section-title" data-en="Sharbel Najem" data-he="שרבל נג'ם">Sharbel Najem</h2>
      <p data-en="A professional filmmaker and commercial content creator, focused on producing high-end video content across social media, lifestyle, tourism, and brand storytelling. With a proven track record in visually rich projects, each one built around a clear strategic objective." data-he="צלם מקצועי ויוצר תוכן שיווקי ומסחרי, מתמחה בהפקת וידאו ברמה גבוהה בתחומי הסושיאל, לייף סטייל, תיירות ותוכן מותגי. עם ניסיון מוכח בפרויקטים עשירים ויזואלית, כל אחד בנוי סביב מטרה אסטרטגית ברורה.">A professional filmmaker and commercial content creator, focused on producing high-end video content across social media, lifestyle, tourism, and brand storytelling. With a proven track record in visually rich projects, each one built around a clear strategic objective.</p>
      <p data-en="Every project begins with a deep understanding of the brand — its identity, audience, and goals. From creative direction and scripting to the final edit, every detail is crafted to connect with the right audience and deliver measurable impact." data-he="כל פרויקט מתחיל מהבנה מעמיקה של המותג — הזהות שלו, קהל היעד והמטרות. מכיוון קריאייטיבי ותסריט ועד לעריכה הסופית, כל פרט מעוצב כדי לפגוע בקהל הנכון ולייצר אימפקט מדיד.">Every project begins with a deep understanding of the brand — its identity, audience, and goals. From creative direction and scripting to the final edit, every detail is crafted to connect with the right audience and deliver measurable impact.</p>
      <div class="about-links">
        <a href="mailto:sharbelnajem9@gmail.com" class="about-link"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>sharbelnajem9@gmail.com</a>
        <a href="https://www.instagram.com/sharbel.najem" class="about-link" target="_blank"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>Instagram <span class="follower-count" id="igCount"></span></a>
        <a href="https://youtube.com/@sharbelnajem." class="about-link" target="_blank"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22.54 6.42a2.78 2.78 0 00-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 00-1.94 2A29 29 0 001 12a29 29 0 00.46 5.58 2.78 2.78 0 001.94 2C5.12 20 12 20 12 20s6.88 0 8.6-.46a2.78 2.78 0 001.94-2A29 29 0 0023 12a29 29 0 00-.46-5.58z"/><polygon points="9.75 15.02 15.5 12 9.75 8.98"/></svg>YouTube</a>
        <a href="https://www.tiktok.com/@sharbelnajem" class="about-link" target="_blank"><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.27 6.27 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.34-6.34V8.75a8.18 8.18 0 004.76 1.52V6.84a4.86 4.86 0 01-1-.15z"/></svg>TikTok <span class="follower-count" id="tkCount"></span></a>
      </div>
    </div>
  </div>
</section>

<!-- SERVICES -->
<section class="services" id="services">
  <div class="services-header fade-in">
